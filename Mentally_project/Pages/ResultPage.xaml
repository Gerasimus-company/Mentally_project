<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Mentally_project.Pages.ResultPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Результат"
             BackgroundColor="#1a1a2e">

    <Grid RowDefinitions="Auto, *, Auto" Padding="25" RowSpacing="20">
        
        <!-- Result Circle and Code -->
        <StackLayout Grid.Row="0" 
                     HorizontalOptions="Center" 
                     Spacing="15"
                     Margin="0,30,0,20">
            <!-- Animated Circle -->
            <Frame WidthRequest="150"
                   HeightRequest="150"
                   CornerRadius="75"
                   Padding="0"
                   IsClippedToBounds="True"
                   BorderColor="#667eea"
                   BackgroundColor="#252550"
                   HasShadow="True">
                <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label x:Name="ResultCodeLabel"
                           Text="ENFJ"
                           FontFamily="RMR"
                           FontSize="36"
                           TextColor="#667eea"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </StackLayout>
            </Frame>
        </StackLayout>

        <!-- Result Description -->
        <ScrollView Grid.Row="1" VerticalOptions="Fill">
            <StackLayout Spacing="15">
                <Label x:Name="ResultTitleLabel"
                       Text="Протагонист"
                       FontFamily="RMR"
                       FontSize="24"
                       TextColor="#FFFFFF"
                       HorizontalOptions="Center"/>
                
                <BoxView HeightRequest="1" 
                         BackgroundColor="#25D9d9d9"
                         HorizontalOptions="Fill"
                         Margin="0,10"/>
                
                <Label x:Name="ResultDescriptionLabel"
                       Text="Харизматичные лидеры, способные вдохновлять других..."
                       FontFamily="RML"
                       FontSize="14"
                       TextColor="#D9d9d9"
                       LineHeight="1.5"/>
            </StackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <StackLayout Grid.Row="2" Spacing="10" Margin="0,20,0,0">
            <Button Text="📤 Поделиться"
                    FontFamily="RMR"
                    TextColor="White"
                    FontSize="16"
                    BackgroundColor="#667eea"
                    CornerRadius="12"
                    Padding="20"
                    Clicked="OnShareClicked"/>
            
            <Button Text="💾 Сохранить в дневник"
                    FontFamily="RMR"
                    TextColor="White"
                    FontSize="16"
                    BackgroundColor="#25D9d9d9"
                    CornerRadius="12"
                    Padding="20"
                    Clicked="OnSaveToDiaryClicked"/>
            
            <Button Text="← На главную"
                    FontFamily="RMR"
                    TextColor="White"
                    FontSize="16"
                    BackgroundColor="Transparent"
                    BorderColor="#25D9d9d9"
                    BorderWidth="1"
                    CornerRadius="12"
                    Padding="20"
                    Clicked="OnBackToHomeClicked"/>
        </StackLayout>
    </Grid>
</ContentPage>
