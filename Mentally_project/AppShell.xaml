<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Mentally_project.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Mentally_project.Pages"
    Title="Mentally_project">

    <ShellContent
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Shell.FlyoutBehavior="Disabled"
        ContentTemplate="{DataTemplate local:TestsListPage}"
        Route="TestsList" />

    <ShellContent
        Shell.FlyoutBehavior="Disabled"
        ContentTemplate="{DataTemplate local:TestPassingPage}"
        Route="TestPassing" />

    <ShellContent
        Shell.FlyoutBehavior="Disabled"
        ContentTemplate="{DataTemplate local:ResultPage}"
        Route="Result" />

</Shell>
